<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/profile_CV_image"
        android:layout_width="100dp"
        android:layout_height="80dp"
        android:layout_marginVertical="@dimen/poster_margin"
        android:layout_marginStart="6dp"
        app:cardCornerRadius="@dimen/corner_radius"
        app:cardElevation="@dimen/poster_elevation"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <androidx.appcompat.widget.AppCompatImageView
            android:id="@+id/profile_IMG"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:scaleType="centerCrop"
            app:srcCompat="@drawable/ic_launcher_background"
            tools:ignore="ContentDescription" />
    </com.google.android.material.card.MaterialCardView>

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/profile_CV_data"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="10dp"
        app:cardCornerRadius="@dimen/event_corner_radius"
        app:cardElevation="@dimen/event_data_elevation"
        app:layout_constraintStart_toEndOf="@id/profile_CV_image"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="@id/profile_CV_image"
        app:layout_constraintBottom_toBottomOf="@id/profile_CV_image">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="@dimen/event_card_padding">

            <com.google.android.material.textview.MaterialTextView
                android:id="@+id/profile_LBL_title"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginEnd="80dp"
                android:maxLines="2"
                android:textStyle="bold"
                android:textSize="@dimen/event_title_size"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                tools:text="Event Name" />

            <com.google.android.material.textview.MaterialTextView
                android:id="@+id/profile_LBL_dateTime"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:textSize="@dimen/event_text_size"
                app:layout_constraintStart_toStartOf="@id/profile_LBL_title"
                app:layout_constraintTop_toBottomOf="@id/profile_LBL_title"
                tools:text="15.04.2026 • 19:00" />

            <com.google.android.material.textview.MaterialTextView
                android:id="@+id/profile_LBL_address"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:textSize="@dimen/event_text_size"
                app:layout_constraintStart_toStartOf="@id/profile_LBL_title"
                app:layout_constraintEnd_toEndOf="@id/profile_LBL_title"
                app:layout_constraintTop_toBottomOf="@id/profile_LBL_dateTime"
                tools:text="Tel Aviv-Yafo, Israel" />

            <androidx.appcompat.widget.AppCompatImageView
                android:id="@+id/profile_BTN_edit"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:layout_marginTop="4dp"
                android:layout_marginEnd="35dp"
                android:padding="6dp"
                android:clickable="true"
                android:focusable="true"
                android:contentDescription="@string/edit_event"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:srcCompat="@drawable/ic_edit" />

            <androidx.appcompat.widget.AppCompatImageView
                android:id="@+id/profile_BTN_delete"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:layout_marginTop="4dp"
                android:layout_marginEnd="4dp"
                android:padding="4dp"
                android:clickable="true"
                android:focusable="true"
                android:contentDescription="@string/delete_event"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:srcCompat="@drawable/ic_delete" />

        </androidx.constraintlayout.widget.ConstraintLayout>
    </com.google.android.material.card.MaterialCardView>

</androidx.constraintlayout.widget.ConstraintLayout>